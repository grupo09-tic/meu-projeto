model Questionario {
  id          BigInt                  @id @default(autoincrement()) @map("pkQuestionario")
  urlVideo    String?                 @map("urlVideo") @db.VarChar(255)
  dataInicio  DateTime                @map("datainicio") @db.Date
  dataTermino DateTime                @map("dataTermino") @db.Date
  identificar Int                     @map("identificar") @db.SmallInt

  perguntas   Pergunta[]
  respostas   Resposta[]
  aplicacoes  AplicacaoQuestionario[]

  @@map("tbQuestionario")
}
