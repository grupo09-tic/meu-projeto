model Colaborador {
  id              BigInt   @id @default(autoincrement()) @map("pkColaborador")
  nome            String   @map("nomeColaborador") @db.VarChar(100)
  matricula       String   @map("matricula") @db.VarChar(50)
  departamentoId  BigInt   @map("fkDepartamento")
  empresaId       BigInt   @map("fkEmpresa")

  departamento    Departamento @relation(fields: [departamentoId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  empresa         Empresa      @relation(fields: [empresaId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  aplicacoes      AplicacaoQuestionario[]

  @@map("tbColaborador")
}
