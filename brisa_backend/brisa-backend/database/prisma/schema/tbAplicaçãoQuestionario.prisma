model AplicacaoQuestionario {
  id             BigInt       @id @default(autoincrement()) @map("pkAplicacaoQuestionario")
  respondido     Int          @map("respondido") @db.SmallInt // 0=Não, 1=Sim/Pendente
  colaboradorId  BigInt       @map("fkColaborador")
  questionarioId BigInt       @map("fkQuestionario")

  colaborador    Colaborador  @relation(fields: [colaboradorId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  questionario   Questionario @relation(fields: [questionarioId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  respostas      Resposta[]

  @@map("tbAplicacaoQuestionario")
}
